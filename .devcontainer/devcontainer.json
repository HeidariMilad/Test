{
  "name": "Easy SOCKS5 Proxy",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [443],
  "portsAttributes": {
    "443": {
      "label": "SOCKS5 Proxy",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postStartCommand": "nohup easy-socks5 > /workspaces/Test/socks5.log 2>&1 &",
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "golang.go"
      ]
    }
  }
}
